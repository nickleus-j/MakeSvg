  "item": [
    {
      "name": "Random Generation",
      "item": [
        {
          "name": "GET /random - Default",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is SVG content', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('svg');",
                  "});",
                  "pm.test('Response body contains SVG tag', function () {",
                  "    pm.expect(pm.response.text()).to.include('<svg');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/random"
          }
        },
        {
          "name": "GET /random/{width}/{height}",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is SVG content', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('svg');",
                  "});",
                  "pm.test('Response contains SVG with correct dimensions', function () {",
                  "    pm.expect(pm.response.text()).to.include('width=\"200\"');",
                  "    pm.expect(pm.response.text()).to.include('height=\"200\"');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/random/200/200"
          }
        }
      ]
